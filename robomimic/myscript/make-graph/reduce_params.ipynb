    "import pandas as pd \n",
    "import glob \n",
    "import re \n",
    "# ===================== # 入力パターン # ===================== \n",
    "patterns = [ \"/work/robomimic/csv/eval/lift/quantize/all/weight-6bit/ADC-DAC-8bit/LUT-4bit/CAM-5bit/5-5/unit*.csv\", \n",
    "            \"/work/robomimic/csv/eval/lift/quantize/all/weight-6bit/ADC-DAC-8bit/LUT-4bit/CAM-6bit/5-5/unit*.csv\", \n",
    "            \"/work/robomimic/csv/eval/lift/quantize/all/weight-6bit/ADC-DAC-8bit/LUT-4bit/CAM-6bit/6-4/unit*.csv\", \n",
    "            \"/work/robomimic/csv/eval/lift/quantize/all/weight-6bit/ADC-DAC-8bit/LUT-4bit/CAM-6bit/6-5/unit*.csv\", \n",
    "            \"/work/robomimic/csv/eval/lift/quantize/all/weight-5bit/ADC-DAC-8bit/LUT-4bit/CAM-5bit/5-5/unit*.csv\", \n",
    "            \"/work/robomimic/csv/eval/lift/quantize/all/weight-5bit/ADC-DAC-8bit/LUT-4bit/CAM-6bit/6-5/unit*.csv\", ] \n",
    "# ===================== # パラメータ数定義 # ===================== \n",
    "def calc_params(units, cam_bit): \n",
    "    return { \"weight\": (units + 19) * units, \"CAM\": 2**cam_bit * (units + 19), \"LUT\": 2**cam_bit * units, \"SRAM\": 3 * units, \"RRAM\": units, }\n",
    "UNITS = { \"u64\": 64, \"u128\": 128, \"u256\": 256, }\n",
    "\n",
    "# =====================\n",
    "# 定数\n",
    "# =====================\n",
    "FP32 = 32\n",
    "INT8 = 8\n",
    "\n",
    "# =====================\n",
    "# パラメータ数\n",
    "# =====================\n",
    "def calc_params(units, cam_bit):\n",
    "    return {\n",
    "        \"weight\": (units + 19) * units,\n",
    "        \"CAM\": 2**cam_bit * (units + 19),\n",
    "        \"LUT\": 2**cam_bit * units,\n",
    "        \"SRAM\": 3 * units,\n",
    "        \"RRAM\": units,\n",
    "    }\n",
    "\n",
    "# =====================\n",
    "# Utility\n",
    "# =====================\n",
    "def extract_base_model(name: str):\n",
    "    name = re.sub(r\"_seed\\d+\", \"\", name)\n",
    "    name = name.replace(\"unit64\", \"u64\")\n",
    "    name = name.replace(\"unit128\", \"u128\")\n",
    "    name = name.replace(\"unit256\", \"u256\")\n",
    "    return name\n",
    "\n",
    "def extract_bits_from_path(path: str):\n",
    "    bits = {\n",
    "        \"weight\": FP32,\n",
    "        \"CAM\": INT8,\n",
    "        \"LUT\": FP32,\n",
    "        \"SRAM\": FP32,\n",
    "        \"RRAM\": FP32,\n",
    "    }\n",
    "\n",
    "    for key in [\"weight\", \"LUT\", \"CAM\"]:\n",
    "        m = re.search(fr\"{key}-(\\d+)bit\", path)\n",
    "        if m:\n",
    "            bits[key] = int(m.group(1))\n",
    "\n",
    "    m = re.search(r\"/(\\d+)-(\\d+)/\", path)\n",
    "    if m:\n",
    "        bits[\"SRAM\"], bits[\"RRAM\"] = map(int, m.groups())\n",
    "\n",
    "    return bits\n",
    "\n",
    "def short_label(bits):\n",
    "    return (\n",
    "        f\"W{bits['weight']}\"\n",
    "        f\"-CAM{bits['CAM']}\"\n",
    "        f\"-LUT{bits['LUT']}\"\n",
    "        f\"-S{bits['SRAM']}\"\n",
    "        f\"-R{bits['RRAM']}\"\n",
    "    )\n",
    "\n",
    "# =====================\n",
    "# 集計\n",
    "# =====================\n",
    "records = []\n",
    "\n",
    "for pattern in patterns:\n",
    "    csv_files = glob.glob(pattern)\n",
    "    print(f\"[INFO] {pattern} -> {len(csv_files)} files\")\n",
    "\n",
    "    if not csv_files:\n",
    "        continue\n",
    "\n",
    "    bit_cfg = extract_bits_from_path(pattern)\n",
    "    label = short_label(bit_cfg)\n",
    "\n",
    "    df_all = pd.concat(\n",
    "        [\n",
    "            pd.read_csv(f).assign(\n",
    "                base_model=lambda x: x[\"name\"].apply(extract_base_model)\n",
    "            )\n",
    "            for f in csv_files\n",
    "        ],\n",
    "        ignore_index=True,\n",
    "    )\n",
    "\n",
    "    df_avg = df_all.groupby(\"base_model\")[\"success_rate\"].mean().reset_index()\n",
    "\n",
    "    for _, row in df_avg.iterrows():\n",
    "        model = row[\"base_model\"]\n",
    "        m = re.search(r\"u(\\d+)\", model)\n",
    "        if not m:\n",
    "            continue\n",
    "        units = int(m.group(1))\n",
    "\n",
    "        base_params = calc_params(units, cam_bit=8)\n",
    "        quant_params = calc_params(units, cam_bit=bit_cfg[\"CAM\"])\n",
    "\n",
    "        base_bits = (\n",
    "            base_params[\"weight\"] * FP32 +\n",
    "            base_params[\"CAM\"]    * INT8 +\n",
    "            base_params[\"LUT\"]    * FP32 +\n",
    "            base_params[\"SRAM\"]   * FP32 +\n",
    "            base_params[\"RRAM\"]   * FP32\n",
    "        )\n",
    "\n",
    "        quant_bits = (\n",
    "            quant_params[\"weight\"] * bit_cfg[\"weight\"] +\n",
    "            quant_params[\"CAM\"]    * bit_cfg[\"CAM\"] +\n",
    "            quant_params[\"LUT\"]    * bit_cfg[\"LUT\"] +\n",
    "            quant_params[\"SRAM\"]   * bit_cfg[\"SRAM\"] +\n",
    "            quant_params[\"RRAM\"]   * bit_cfg[\"RRAM\"]\n",
    "        )\n",
    "\n",
    "        records.append({\n",
    "            \"config\": label,\n",
    "            \"model\": model,\n",
    "            \"success_%\": row[\"success_rate\"] * 100,\n",
    "            \"base_bits_M\": base_bits / 1e6,\n",
    "            \"quant_bits_M\": quant_bits / 1e6,\n",
    "            \"reduction_%\": (1 - quant_bits / base_bits) * 100,\n",
    "        })\n",
    "\n",
    "# =====================\n",
    "# 出力\n",
    "# =====================\n",
    "df = pd.DataFrame(records).sort_values([\"config\", \"model\"])\n",
    "\n",
    "print(df.to_string(index=False, float_format=\"%.2f\"))\n"
   ]
  },
